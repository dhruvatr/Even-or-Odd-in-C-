#include <iostream>
#include <string>
using namespace std;

int main() {
    string password;
    int score = 0;

    cout << "Enter Password: ";
    cin >> password;

    // Length Check
    if(password.length() >= 8)
        score++;

    // Uppercase Check
    for(char ch : password) {
        if(ch >= 'A' && ch <= 'Z') {
            score++;
            break;
        }
    }

    // Number Check
    for(char ch : password) {
        if(ch >= '0' && ch <= '9') {
            score++;
            break;
        }
    }

    // Special Character Check
    for(char ch : password) {
        if(!(ch >= 'A' && ch <= 'Z') &&
           !(ch >= 'a' && ch <= 'z') &&
           !(ch >= '0' && ch <= '9')) {
            score++;
            break;
        }
    }

    // Result
    if(score <= 1)
        cout << "Weak Password";
    else if(score == 2 || score == 3)
        cout << "Medium Password";
    else
        cout << "Strong Password";

    return 0;
}