#include <iostream>
using namespace std;

int main() {
    int num = 153, sum = 0, temp = num;

    while (temp > 0) {
        int digit = temp % 10;
        sum += digit * digit * digit;
        temp /= 10;
    }

    if (sum == num)
        cout << "Armstrong Number";
    else
        cout << "Not Armstrong Number";

    return 0;
}