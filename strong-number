#include <iostream>
using namespace std;

int fact(int n){
    int f=1;
    for(int i=1;i<=n;i++)
        f*=i;
    return f;
}

int main(){
    int num, sum=0, temp, rem;
    cout<<"Enter a number: ";
    cin>>num;

    temp=num;

    while(temp>0){
        rem=temp%10;
        sum=sum+fact(rem);
        temp=temp/10;
    }

    if(sum==num)
        cout<<"Strong Number";
    else
        cout<<"Not a Strong Number";

    return 0;
}