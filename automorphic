#include <iostream>
using namespace std;

int main() {
    int num, square, temp;
    cout << "Enter number: ";
    cin >> num;

    square = num * num;
    temp = num;

    while (temp > 0) {
        if (temp % 10 != square % 10) {
            cout << "Not Automorphic";
            return 0;
        }
        temp /= 10;
        square /= 10;
    }

    cout << "Automorphic Number";
    return 0;
}di